{
  "name": "ai-video-editor",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter openvideo --filter editor dev",
    "build": "pnpm --filter editor build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "turbo": "^2.8.20",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.8",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "dependencies": {
    "assistant-stream": "^0.3.0"
  },
  "packageManager": "pnpm@10.30.3"
}
